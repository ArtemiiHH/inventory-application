<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sidebar</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- Filters -->
      <form action="/products" method="GET">
        
        <!-- Price -->
        <div class="filter-section">
          <label class="filter-label"><strong>Price:</strong></label>
          <div class="price-sort">
            <button
              type="submit"
              name="sort"
              value="asc"
              class="sort-btn <%= sort === 'asc' ? 'active' : '' %>"
            >
              Low → High
            </button>
            <button
              type="submit"
              name="sort"
              value="desc"
              class="sort-btn <%= sort === 'desc' ? 'active' : '' %>"
            >
              High → Low
            </button>
          </div>
        </div>

        <!-- Brand -->
        <div class="filter-section">
          <label class="filter-label"><strong>Brand:</strong></label>
        </div>
      </form>
    </aside>
  </body>
</html>
