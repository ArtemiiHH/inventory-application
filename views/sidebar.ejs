<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sidebar</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- Filters -->
      <form action="/products" method="GET">
        
        <!-- Price filters -->
        <div class="filter-section">
          <label class="filter-label"><strong>Price:</strong></label>
          <div class="price-sort">
            <button
              type="submit"
              name="sort"
              value="asc"
              class="sort-btn <%= sort === 'asc' ? 'active' : '' %>"
            >
              Low → High
            </button>
            <button
              type="submit"
              name="sort"
              value="desc"
              class="sort-btn <%= sort === 'desc' ? 'active' : '' %>"
            >
              High → Low
            </button>
          </div>
        </div>

        <!-- Hidden inputs to preserve brand/category when clicking sort buttons -->
        <% (brands || []).forEach(b => { %>
          <input type="hidden" name="brand" value="<%= b %>" />
        <% }) %>
        <% (categories || []).forEach(c => { %>
          <input type="hidden" name="category" value="<%= c %>" />
        <% }) %>

        <!-- Brand checkboxes -->
        <div class="filter-section">
          <label class="filter-label"><strong>Brand:</strong></label>
          <% allBrands.forEach(b => { %>
            <label>
              <input type="checkbox" name="brand" value="<%= b %>"
                <%= (brands || []).includes(b) ? 'checked' : '' %> />
              <%= b %>
            </label>
          <% }) %>
          <button type="submit">Apply</button>
        </div>

        <!-- Category checkboxes -->
        <div class="filter-section">
          <label class="filter-label"><strong>Category:</strong></label>
          <% allCategories.forEach(c => { %>
            <label>
              <input type="checkbox" name="category" value="<%= c %>"
                <%= (categories || []).includes(c) ? 'checked' : '' %> />
              <%= c %>
            </label>
          <% }) %>
          <button type="submit">Apply</button>
        </div>
      </form>
    </aside>
  </body>
</html>
